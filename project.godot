; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Emberveil"
run/main_scene="uid://xweh4jd5jbfj"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=144
config/icon="res://icon.svg"

[autoload]

DebugManager="*uid://bqo3eyqa1jycn"
SignalBus="*uid://c7v6du1kbbgc1"
GameManager="*uid://dw7u2aulva3fh"
Layers="*uid://mngkneehkcvj"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[global_group]

player=""
interactable=""
fireplace=""
enemy_nest=""
enemy=""
death_screen=""
lantern="grupo pra debug no devtools"
world_environment=""
resource_pickup=""
spawn_point=""
powerup_manager=""
wood_depot=""
